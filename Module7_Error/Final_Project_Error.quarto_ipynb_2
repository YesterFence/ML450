    "# Some airport codes are numeric FAA IDs (e.g. 10135) mixed with IATA strings — cast all to str first\n",
    "df_cleaned['airport_code'] = df_cleaned['airport_code'].astype(str)\n",
    "\n",
    "# Encode airport_code as an integer so it shows up in the correlation matrix\n",
    "le = LabelEncoder()\n",
    "df_cleaned['airport_code_enc'] = le.fit_transform(df_cleaned['airport_code'])\n",
    "\n",
    "feature_cols = ['airport_code_enc', 'month', 'num_of_flights_total',\n",
    "                'num_of_delays_weather', 'num_of_delays_carrier',\n",
    "                'num_of_delays_late_aircraft']\n",
    "\n",
    "corr = df_cleaned[feature_cols + ['delay_rate']].corr()\n",
    "\n",
    "plt.figure(figsize=(8, 6))\n",
    "sns.heatmap(corr[['delay_rate']].sort_values('delay_rate', ascending=False),\n",
    "            annot=True, fmt='.2f', cmap='coolwarm', vmin=-1, vmax=1)\n",
    "plt.title('Feature Correlation with delay_rate')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
