    "mfd_clean = mfd.replace(-999, np.nan)\n",
    "\n",
    "# Compute target — num_of_delays_total is the numerator so drop it after\n",
    "mfd_clean['delay_rate'] = mfd_clean['num_of_delays_total'] / mfd_clean['num_of_flights_total']\n",
