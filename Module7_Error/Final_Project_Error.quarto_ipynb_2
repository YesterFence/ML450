   "outputs": [],
   "source": [
    "df_cleaned = flights.groupby(['ORIGIN_AIRPORT', 'MONTH']).agg(\n",
    "    num_of_flights_total=('FLIGHT_NUMBER', 'count'),\n",
    "    # Keep num_of_delays_total only to compute the target, then drop it\n",
    "    num_of_delays_total=('DEPARTURE_DELAY', lambda x: (x > 15).sum()),\n",
    "    # minutes_delayed_total removed — directly encodes delay severity (leakage)\n",
    "    num_of_delays_weather=('WEATHER_DELAY', lambda x: (x > 0).sum()),\n",
    "    num_of_delays_carrier=('AIRLINE_DELAY', lambda x: (x > 0).sum()),\n",
    "    num_of_delays_late_aircraft=('LATE_AIRCRAFT_DELAY', lambda x: (x > 0).sum())\n",
    ").reset_index()\n",
    "\n",
    "df_cleaned = df_cleaned.rename(columns={'ORIGIN_AIRPORT': 'airport_code', 'MONTH': 'month'})\n",
    "\n",
    "# Compute target first, then drop its numerator so it can't leak into features\n",
    "df_cleaned['delay_rate'] = df_cleaned['num_of_delays_total'] / df_cleaned['num_of_flights_total']\n",
    "df_cleaned = df_cleaned.drop(columns=['num_of_delays_total'])"
   ]
