    "    n_jobs=-1\n",
    ")\n",
    "forest.fit(X_train, y_train)\n",
    "y_pred = forest.predict(X_test)\n",
    "\n",
    "print(classification_report(y_test, y_pred, target_names=['Not Delayed', 'Delayed']))"
   ]
