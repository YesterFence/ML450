   "source": [
    "## Data Preparation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "ee5e9b5e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "is_delayed\n",
      "0    4712659\n",
      "1    1106420\n",
      "Name: count, dtype: int64\n",
      "\n",
      "Overall delay/cancel rate: 19.01%\n"
     ]
    }
   ],
   "source": [
    "# Target: 1 if flight was delayed more than 15 min OR cancelled, 0 otherwise\n",
    "# DEPARTURE_DELAY is NaN for cancelled flights, so we handle both together\n",
    "flights['is_delayed'] = (\n",
    "    (flights['DEPARTURE_DELAY'] > 15) | (flights['CANCELLED'] == 1)\n",
    ").astype(int)\n",
    "\n",
    "print(flights['is_delayed'].value_counts())\n",
    "print(f\"\\nOverall delay/cancel rate: {flights['is_delayed'].mean():.2%}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "01315252",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Model dataset shape: (5819079, 9)\n",
      "   MONTH  DAY  DAY_OF_WEEK  AIRLINE  ORIGIN_AIRPORT  DESTINATION_AIRPORT  \\\n",
      "0      1    1            4        1             323                  584   \n",
      "1      1    1            4        0             482                  542   \n",
      "2      1    1            4       11             584                  373   \n",
      "3      1    1            4        0             482                  510   \n",
      "4      1    1            4        1             583                  324   \n",
      "\n",
      "   DISTANCE  is_delayed  departure_hour  \n",
      "0      1448           0               0  \n",
      "1      2330           0               0  \n",
      "2      2296           0               0  \n",
      "3      2342           0               0  \n",
      "4      1448           0               0  \n"
     ]
    }
   ],
   "source": [
    "# Keep only pre-flight features — nothing knowable only after the plane departs\n",
    "feature_cols = ['MONTH', 'DAY', 'DAY_OF_WEEK', 'AIRLINE',\n",
    "                'ORIGIN_AIRPORT', 'DESTINATION_AIRPORT',\n",
    "                'SCHEDULED_DEPARTURE', 'DISTANCE']\n",
    "\n",
    "df_model = flights[feature_cols + ['is_delayed']].copy()\n",
    "\n",
    "# ORIGIN_AIRPORT and DESTINATION_AIRPORT can be mixed int/str — cast all to str\n",
    "for col in ['AIRLINE', 'ORIGIN_AIRPORT', 'DESTINATION_AIRPORT']:\n",
    "    df_model[col] = df_model[col].astype(str)\n",
    "\n",
    "# Drop rows missing any feature or the target\n",
    "df_model = df_model.dropna()\n",
    "\n",
    "# Extract departure hour from SCHEDULED_DEPARTURE (e.g. 1430 → 14)\n",
    "# Evening flights accumulate cascading delays — this is a strong predictor\n",
    "df_model['departure_hour'] = (df_model['SCHEDULED_DEPARTURE'] // 100).astype(int)\n",
    "df_model = df_model.drop(columns=['SCHEDULED_DEPARTURE'])\n",
    "\n",
    "# Update feature_cols to reflect the swap\n",
    "feature_cols = ['MONTH', 'DAY', 'DAY_OF_WEEK', 'AIRLINE',\n",
    "                'ORIGIN_AIRPORT', 'DESTINATION_AIRPORT',\n",
    "                'departure_hour', 'DISTANCE']\n",
    "\n",
    "# Encode each categorical column with its own LabelEncoder\n",
    "encoders = {}\n",
    "for col in ['AIRLINE', 'ORIGIN_AIRPORT', 'DESTINATION_AIRPORT']:\n",
    "    le = LabelEncoder()\n",
    "    df_model[col] = le.fit_transform(df_model[col])\n",
    "    encoders[col] = le  # save in case we need to decode later\n",
    "\n",
    "print(f\"Model dataset shape: {df_model.shape}\")\n",
    "print(df_model.head())"
   ]
  },
