    "# Label each cell of the confusion matrix for the bar chart\n",
    "tn, fp, fn, tp = cm.ravel()\n",
    "total = tn + fp + fn + tp\n",
    "\n",
    "labels  = ['True Negative\\n(Correct: Not Delayed)', 'False Positive\\n(Wrong: Said Delayed)',\n",
    "           'False Negative\\n(Wrong: Missed Delay)',  'True Positive\\n(Correct: Delayed)']\n",
    "counts  = [tn, fp, fn, tp]\n",
    "colors  = ['steelblue', 'tomato', 'tomato', 'steelblue']\n",
    "\n",
    "plt.figure(figsize=(9, 5))\n",
    "bars = plt.bar(labels, counts, color=colors, edgecolor='white', width=0.5)\n",
    "\n",
    "# Annotate each bar with count and percentage\n",
    "for bar, count in zip(bars, counts):\n",
    "    pct = count / total * 100\n",
    "    plt.text(bar.get_x() + bar.get_width() / 2,\n",
    "             bar.get_height() + total * 0.005,\n",
    "             f'{count:,}\\n({pct:.1f}%)',\n",
    "             ha='center', va='bottom', fontsize=9)\n",
    "\n",
    "plt.title('Confusion Matrix — Bar Chart')\n",
