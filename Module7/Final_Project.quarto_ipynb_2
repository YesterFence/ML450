     ]
    }
   ],
   "source": [
    "# Replace label-encoded airport/airline integers with their historical delay rate\n",
    "# Computed only from training rows to avoid leakage into the test set\n",
    "X_train = X_train.copy()\n",
    "X_test  = X_test.copy()\n",
    "\n",
    "for col in ['ORIGIN_AIRPORT', 'DESTINATION_AIRPORT', 'AIRLINE']:\n",
    "    rate_map = X_train.assign(is_delayed=y_train).groupby(col)['is_delayed'].mean()\n",
    "    X_train[col] = X_train[col].map(rate_map)\n",
    "    # Test set airports not seen in training get the overall training mean\n",
    "    X_test[col]  = X_test[col].map(rate_map).fillna(y_train.mean())\n",
    "\n",
    "print(\"Sample of target-encoded training features:\")\n",
    "print(X_train.head())"
   ]
  },
